LOCAL_DIR := $(GET_LOCAL_DIR)

MODULE := $(LOCAL_DIR)

PLATFORM := rp23xx

GLOBAL_DEFINES += \
	TARGET_HAS_DEBUG_LED=1 \
	CUSTOM_DEFAULT_STACK_SIZE=4096 \
	PICO_FLASH_SPI_CLKDIV=2 \
	PICO_FLASH_SIZE_BYTES=0x400000 \
	PICO_USE_GPIO_COPROCESSOR=0 \
	PICO_FLOAT_SUPPORT_ROM_V1=1 \
	PICO_DOUBLE_SUPPORT_ROM_V1=1

MODULE_SRCS += \
	$(LOCAL_DIR)/boot.stage2.S \
	$(LOCAL_DIR)/image_def.S \
	$(LOCAL_DIR)/target.c \
	$(LOCAL_DIR)/usb.c

MODULE_DEPS += \
	dev/usb

include make/module.mk
